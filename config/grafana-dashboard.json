{
  "dashboard": {
    "id": null,
    "title": "Fastify 應用程式指標",
    "tags": ["fastify", "prometheus"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "HTTP 請求總數",
        "type": "graph",
        "targets": [
          {
            "expr": "http_requests_total",
            "legendFormat": "{{method}} {{route}} {{status_code}}"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 0
        }
      },
      {
        "id": 2,
        "title": "CPU 使用率",
        "type": "graph",
        "targets": [
          {
            "expr": "process_cpu_user_seconds_total",
            "legendFormat": "用戶 CPU"
          },
          {
            "expr": "process_cpu_system_seconds_total",
            "legendFormat": "系統 CPU"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 0
        }
      }
    ],
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "timepicker": {},
    "templating": {
      "list": []
    },
    "annotations": {
      "list": []
    },
    "refresh": "5s",
    "schemaVersion": 16,
    "version": 0,
    "links": []
  }
}